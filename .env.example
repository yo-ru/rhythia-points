# ─── Database ───────────────────────────────────────────────────────────
#
# Local development: both URLs point at the Docker Postgres.
# Neon: use the *pooled* connection string for DATABASE_URL and the *direct*
# connection string for DIRECT_URL. Neon's dashboard exposes both.
DATABASE_URL="postgres://rhythia:rhythia@localhost:5432/rhythia_points"
DIRECT_URL="postgres://rhythia:rhythia@localhost:5432/rhythia_points"

# ─── Rhythia API ────────────────────────────────────────────────────────
#
# Environment: "production" is the public site.
RHYTHIA_ENV="production"

# Session JWT — paste from devtools while signed in to rhythia.com.
# These expire ~7 days from issue.
RHYTHIA_SESSION=""

# ─── Scrape tunables ────────────────────────────────────────────────────
#
# Top-N players to walk via getLeaderboard.
#   50    ≈ 70s scrape, ~460 unique maps      (sanity check)
#   10000 ≈ 70min scrape, tens of thousands   (full run)
SCRAPE_PLAYER_LIMIT=10000

# Cap on enrichment + variant rebuild. Scrapes pick up more maps than we
# usefully enrich; this trims the long tail by ordering on score-count desc.
SCRAPE_MAP_LIMIT=20000

# Sleep between upstream API calls (ms). Don't go below 150ms.
SCRAPE_DELAY_MS=200
